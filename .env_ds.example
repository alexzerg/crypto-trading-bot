CRYPTOCOM_API_KEY=XXXXXXXXXXXXXXXXXXXXXX
CRYPTOCOM_SECRET_KEY=cxakp_XXXXXXXXXXXXXXXXXXXXXXXX
DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_USER_IDS=XXXXXXXXX

# ============ CAPITAL & POSITION SIZING ============
INITIAL_CAPITAL=500.0
POSITION_SIZE_PERCENT=10.0
MAX_CONCURRENT_POSITIONS=4

# ============ TRADING SYMBOLS ============
TRADING_SYMBOLS=ETH,SOL,AVAX,ADA,DOT,LINK

# ============ TARGETS & STOPS ============
# LONG POSITIONS
PROFIT_TARGET=6.0
STOP_LOSS=1.5
TRAILING_STOP_ACTIVATE=2.0
TRAILING_STOP_DISTANCE=1.0

# SHORT POSITIONS (different parameters)
SHORT_PROFIT_TARGET=3.0
SHORT_STOP_LOSS=1.0
SHORT_TRAILING_ACTIVATE=1.5

# ============ TRADING FREQUENCY ============
CYCLE_DELAY=30
MAX_CONSECUTIVE_LOSSES=5
DAILY_TRADE_LIMIT=30
MIN_CYCLE_BETWEEN_TRADES=5

# ============ RISK MANAGEMENT ============
DAILY_LOSS_LIMIT=10.0
MAX_DRAWDOWN=20.0
MIN_BALANCE_FOR_TRADING=100.0

# ============ TECHNICAL PARAMETERS ============
MIN_DIP_PERCENT=1.0
CONFIRMATION_CANDLES=2
RSI_BUY_MAX=58.0
RSI_SELL_MIN=80.0 
CONFIDENCE_THRESHOLD=0.35

# ============ REGIME DETECTION ============
REGIME_LOOKBACK=35
REGIME_UPDATE_INTERVAL=3
MIN_REGIME_STRENGTH=0.35

# ============ VOLATILITY ============
MAX_VOLATILITY=70.0

# ============ AI SETTINGS ============
AI_CACHE_TTL=300
AI_MAX_DAILY_CALLS=100
AI_TESTING_MODE=true
MIN_AI_CONFIDENCE=0.65

# ============ REGIME MULTIPLIERS ============
# Keep these as they adjust based on market
BULL_POSITION_MULTIPLIER=1.8
BEAR_POSITION_MULTIPLIER=1.2
SIDEWAYS_POSITION_MULTIPLIER=1.5

BULL_PROFIT_MULTIPLIER=1.5
BEAR_PROFIT_MULTIPLIER=1.2
SIDEWAYS_PROFIT_MULTIPLIER=1.3

# ============ EMERGENCY TRADING ============
EMERGENCY_TRADE_AFTER_CYCLES=8
EMERGENCY_TRADE_CHANCE=0.5
FORCE_AI_TRADE_CHANCE=0.4
MIN_DIP_PERCENT_EMERGENCY=0.3
RSI_BUY_MAX_EMERGENCY=40.0

# ============ MARGIN SETTINGS ============
MAX_LEVERAGE=1.0
MARGIN_MULTIPLIER=1.0
MARGIN_CALL_LEVEL=10
POSITION_TIMEOUT=1800
# ============ SHORTING ============
ENABLE_SHORTING=true
SHORT_RSI_MIN=65.0
SHORT_PUMP_MIN=1.5
SHORT_MAX_POSITIONS=2
MAX_TOTAL_POSITIONS=4
SHORT_POSITION_RATIO=0.4

# ============ DEBUGGING ============
VERBOSE_MODE=true
LOG_TRADES_CSV=true
LOG_AI_DECISIONS=true